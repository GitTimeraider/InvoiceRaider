{
  "name": "frontend-svelte",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "bun run copy-version && vite build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "sync-keys": " bun extract-i18n-keys.js",
    "copy-version": "cp ../VERSION ./static/VERSION 2>/dev/null || cp VERSION ./static/VERSION 2>/dev/null || echo 'VERSION file not found'",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "prettier --check . && eslint .",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@sveltejs/adapter-auto": "^7.0.0",
    "@sveltejs/adapter-node": "^5.5.7",
    "@sveltejs/kit": "^2.66.0",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tailwindcss/vite": "^4.3.1",
    "@types/node": "^25.9.2",
    "@typescript-eslint/parser": "^8.62.0",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.19.0",
    "prettier": "^3.8.4",
    "prettier-plugin-svelte": "^4.1.1",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "svelte": "^5.56.3",
    "svelte-check": "^4.7.1",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.16"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "daisyui": "^5.5.23",
    "lucide-svelte": "^1.0.1",
    "qrcode": "^1.5.4"
  }
}
